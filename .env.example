# Required
DATABASE_URL=             # PostgreSQL connection string (e.g., postgresql://bonplan:pass@localhost:5432/bonplan)
REDIS_URL=                # Redis connection string (e.g., redis://:pass@localhost:6379)
ENCRYPTION_KEY=           # AES-256 key (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=       # Session secret (generate: openssl rand -hex 32)
POSTGRES_PASSWORD=        # PostgreSQL password (generate: openssl rand -hex 16)
REDIS_PASSWORD=           # Redis password (generate: openssl rand -hex 16)

# VPN (required for scraping)
PROTON_WG_PRIVATE_KEY=    # ProtonVPN WireGuard private key

# Browser (required for scraping)
BROWSER_WS_URL=           # Chrome CDP endpoint (e.g., ws://localhost:9222)

# Search engine (required for market research)
SEARXNG_URL=              # SearXNG instance URL (e.g., http://localhost:8888)
SEARXNG_SECRET_KEY=       # SearXNG server secret (generate: openssl rand -hex 32)

# Admin (optional)
ADMIN_USER_ID=            # UUID of admin user
GATEWAY_URL=              # Gateway URL for internal service calls (e.g., http://localhost:3000)

# Cloudflare Tunnel (required for production)
CLOUDFLARE_TUNNEL_TOKEN=  # Cloudflare tunnel token (from Zero Trust dashboard)

# Auth (optional, for production)
TRUSTED_ORIGINS=          # Comma-separated allowed origins (e.g., https://bonplan.example.com)
