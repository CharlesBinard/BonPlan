{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!**/parser-snapshots", "!.claude"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			},
			"style": {
				"noDefaultExport": "error",
				"useEnumInitializers": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"css": {
		"parser": { "tailwindDirectives": true }
	},
	"overrides": [
		{
			"includes": ["**/drizzle.config.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"includes": ["**/gateway/src/index.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"includes": ["**/orchestrator/src/index.ts"],
			"linter": { "rules": { "style": { "noDefaultExport": "off" } } }
		},
		{
			"includes": ["**/frontend/vite.config.ts"],
			"linter": { "rules": { "style": { "noDefaultExport": "off" } } }
		},
		{
			"includes": ["**/frontend/orval.config.ts"],
			"linter": { "rules": { "style": { "noDefaultExport": "off" } } }
		},
		{
			"includes": ["**/frontend/src/config/api-mutator.ts"],
			"linter": { "rules": { "style": { "noDefaultExport": "off" } } }
		}
	]
}
